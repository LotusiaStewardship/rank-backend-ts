{
  "exclude": [
    "submodules",
    "node_modules"
  ],
  "compilerOptions": {
    "rootDirs": [
      ".",
      ".output"
    ],
    "outDir": "./.output",
    "paths": {
      "lotus-lib": [
        "./submodules/lotus-lib"
      ],
      "lotus-lib/lib/nng-interface": [
        "./submodules/lotus-lib/lib/nng-interface"
      ]
    },
    "declaration": false,
    "removeComments": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": false,
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "plugins": [
      {
        "transform": "typescript-transform-paths", "useRootDirs": true
      }
    ]
  }
}