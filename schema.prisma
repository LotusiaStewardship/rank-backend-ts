// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./prisma/prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Human identity
model Account {
  id       String    @id
  profiles Profile[]

  @@index([id(type: hash)])
}

// Online profiles related to human identity
// These profiles are the crux of the RANK reputation system, and thus
// are the primary object of the RANK indexer.
//
// The RANK indexer upserts records for posts and comments through the `Profile` model.
//
// All database operations ought to be done through the `Profile` model, and upserts to
// `Post`, `RankTransaction`, and `RankComment` should be done through database relations.
model Profile {
  id            String // Platform-unique ID (e.g. per API)
  accountId     String
  instanceId    String?
  platform      String // e.g. Twitter/X.com
  ranking       BigInt // overall ranking, in satoshis
  satsPositive  BigInt // Total amount of sats burned for positive sentiment
  satsNegative  BigInt // Total amount of sats burned for negative sentiment
  votesPositive Int // Total number of RANK txs with positive sentinment
  votesNegative Int // Total number of RANK txs with negative sentiment
  // RANK txs and comments can be associated with a Profile
  ranks         RankTransaction[]
  comments      RankComment[]
  posts         Post[]
  account       Account?           @relation(fields: [accountId], references: [id])
  instance      ExtensionInstance? @relation(fields: [instanceId], references: [id])

  @@id([platform, id])
  @@index([id(type: hash)])
  // these indexes are best used with a `LIMIT BY`
  // ref: https://www.postgresql.org/docs/current/indexes-ordering.html#INDEXES-ORDERING
  @@index([platform(type: hash), ranking(type: btree, sort: Desc)], name: "profile_idx_ranked_highest")
  @@index([platform(type: hash), ranking(type: btree, sort: Asc)], name: "profile_idx_ranked_lowest")
}

// Posts are indexed by platform, profileId, and postId
// For the Lotusia platform, the profileId is the user's address (P2PKH payload), and the postId is the txid of the RNKC transaction
// For all other platforms, the profileId is the user's unique ID (e.g. username), and the postId is the platform-specific post ID
model Post {
  id            String // Platform-unique post ID
  platform      String // e.g. Lotusia, Twitter/x.com
  profileId     String // Platform profile ID (i.e. username)
  data          Bytes? // the post text, in UInt8Array (decoded from UTF-8)
  ranking       BigInt // Overall post ranking, in satoshis (satsPositive - satsNegative)
  satsPositive  BigInt // Total amount of sats burned for positive sentiment
  satsNegative  BigInt // Total amount of sats burned for negative sentiment
  votesPositive Int // Total number of RANK txs with positive sentiment
  votesNegative Int // Total number of RANK txs with negative sentiment
  comment       RankComment?      @relation("LotusiaPost")
  // Each Post correlates with a Profile
  profile       Profile           @relation(fields: [profileId, platform], references: [id, platform])
  // RANK txs specific to this Post
  ranks         RankTransaction[]
  // RankComments can be associated with a Post
  comments      RankComment[]

  // Each post will require these three entries
  @@id([platform, profileId, id])
  // Unique constraints for relation to RankComment model
  @@unique([id, profileId, data])
  @@index([id(type: hash)])
  // these indexes are best used with a `LIMIT BY`
  // ref: https://www.postgresql.org/docs/current/indexes-ordering.html#INDEXES-ORDERING
  @@index([platform(type: hash), ranking(type: btree, sort: Desc)], name: "post_idx_ranked_highest")
  @@index([platform(type: hash), ranking(type: btree, sort: Asc)], name: "post_idx_ranked_lowest")
}

model RankTransaction {
  // RankTransaction data
  txid          String // 32-byte hex
  outIdx        Int     @default(0) // index of the output that contains the RANK data
  sats          BigInt // amount of sats burned
  firstSeen     BigInt // Time first seen by indexer, only for new mempool transactions
  scriptPayload String // the p2pkh script payload that spent a UTXO for this transaction
  instanceId    String? // the ID of the extension instance that casted the vote
  height        Int? // null for mempool transactions
  timestamp     BigInt? // null until block is connected
  // RankOutput data
  sentiment     String // 1-byte sentiment, 0x00 = negative, 0x01 = positive, and potentially more
  platform      String // references platform field on Profile model
  profileId     String // references id field on Profile model
  postId        String? // optional reference to platform post ID (e.g. x.com/:profileId/status/:postId)
  // each RANK tx is associated with a Profile, else it is invalid
  profile       Profile @relation(fields: [platform, profileId], references: [platform, id])
  // each RANK tx MAY be associated with a Post
  post          Post?   @relation(fields: [platform, profileId, postId], references: [platform, profileId, id])
  // each RANK tx from the mempool does not yet have a Block
  block         Block?  @relation(fields: [height, timestamp], references: [height, timestamp], onDelete: Cascade)
  //instance      ExtensionInstance? @relation(fields: [instanceId, scriptPayload], references: [id, scriptPayload])

  @@id([txid, outIdx])
  // Poll RANK txs for raw SQL queries
  @@index([platform(type: hash), profileId(type: hash)])
  @@index([platform(type: hash), profileId(type: hash), sentiment(type: hash)])
  @@index([platform(type: hash), profileId(type: hash), postId(type: hash), sentiment(type: hash)])
  // Poll RANK txs by height (primarily for block rewinds)
  @@index([height(sort: Desc)])
}

// OP_RETURN output order and spec:
// outIdx 0: OP_RETURN <RNKC> <Platform> <ProfileId> <PostId>
// outIdx 1: OP_RETURN <OP_PUSHDATA1> <Comment byte length> <Comment UTF-8>
// outIdx 2: OP_RETURN <OP_PUSHDATA1> <Comment byte length> <Comment UTF-8 contd.>
//
// outIdx 0 MUST pay a minimum sat/byte fee for each byte of outIdx 1 and 2 (minus OP_RETURN bytes)
// in order for the RANK indexer to process the comment. Fee rate is determined by the RANK indexer.
//
// Example: outIdx 1 uses all 220 available OP_RETURN bytes, and outIdx 2 uses 70 available bytes (290 bytes total)
// If indexer fee rate is 1 XPI/byte, the total burned fee in outIdx 0 MUST be at least 290 XPI.
//
// Comments can be ranked just like other posts on other platforms. The XPI burned in outIdx 0 is used
// as the initial positive ranking for the comment (similar to comments on Reddit which have 1 upvote by default)
//
model RankComment {
  txid               String   @id // 32-byte hex
  outIdx             Int      @default(0) // For RNKC txs, this is always 0
  sats               BigInt // amount of sats burned (this is the default upvote amount for the comment)
  firstSeen          BigInt // Time first seen by indexer
  scriptPayload      String // address that submitted the comment (20-byte P2PKH)
  instanceId         String? // the ID of the extension instance that posted the comment
  height             Int? // null until block is connected
  timestamp          BigInt? // null until block is connected
  // RankComment data, including some data not present in the OP_RETURN protocol
  data               Bytes // the comment text (UTF-8)
  feeRate            Int // fee rate in sat/byte at time of comment insertion to the RANK indexer
  inReplyToPlatform  String // The platform of the profile/post that is being replied to (e.g. Lotusia, Twitter, etc.)
  inReplyToProfileId String? // id of the Profile that is being replied to (if no profileId, then the comment is a Lotusia post)
  inReplyToPostId    String? // id of the Post that is being replied to (requires profileId)
  // each RNKC tx from the mempool does not yet have a Block
  block              Block?   @relation(fields: [height, timestamp], references: [height, timestamp], onDelete: Cascade)
  post               Post     @relation("LotusiaPost", fields: [txid, scriptPayload, data], references: [id, profileId, data])
  // each RankComment is directly replying to a Profile or Post
  repliedProfile     Profile? @relation(fields: [inReplyToPlatform, inReplyToProfileId], references: [platform, id])
  repliedPost        Post?    @relation(fields: [inReplyToPlatform, inReplyToProfileId, inReplyToPostId], references: [platform, profileId, id])

  // Unique constraints for relation to Post model
  // txid = postId, scriptPayload = profileId, data = comment text
  @@unique([txid, scriptPayload, data])
  @@index([scriptPayload(type: hash)])
  @@index([inReplyToPlatform(type: hash), inReplyToProfileId(type: hash)])
  @@index([inReplyToPlatform(type: hash), inReplyToPostId(type: hash)])
  @@index([height(sort: Desc)])
}

model Block {
  hash        String            @unique
  height      Int               @unique
  timestamp   BigInt
  ranksLength Int               @default(0)
  rnkcsLength Int               @default(0)
  ranks       RankTransaction[]
  comments    RankComment[]

  @@unique([height, timestamp])
  @@index([hash(type: hash)])
  @@index([height(sort: Desc)])
  @@index([height, ranksLength(sort: Desc)])
}

// This should be a separate registration database (e.g. like Cashweb Registry)
model ExtensionInstance {
  id             String   @unique
  scriptPayload  String   @unique
  /**
   * Transaction ID of the payment for API access
   */
  //paymentProof  String?           @unique
  authPayloadStr String?  @unique
  createdAt      DateTime @default(now())
  lastSeen       DateTime @default(now())

  // subscriptions to push notifications
  subscriptionId String?

  // relations
  subscription       ExtensionPushSubscription?
  topicSubscriptions ExtensionTopicSubscription[]
  profiles           Profile[]

  @@id([id, scriptPayload])
  @@index([scriptPayload(type: hash)])
  @@index([id(type: hash), scriptPayload(type: hash)])
}

model ExtensionPushSubscription {
  id         String @unique
  instanceId String @unique

  // subscription endpoint data provided by the browser's Push API
  endpoint  String @unique
  p256dhKey String @unique
  authKey   String @unique

  // subscription metadata
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  // relations
  instance ExtensionInstance @relation(fields: [instanceId], references: [id])

  // primary keys and indexes
  @@id([instanceId, id])
  @@index([instanceId(type: hash)])
  @@index([instanceId(type: hash), isActive(type: hash)])
}

model ExtensionTopicSubscription {
  instanceId String
  topic      String
  isActive   Boolean           @default(false)
  createdAt  DateTime          @default(now())
  lastUsed   DateTime          @default(now())
  // relations
  instance   ExtensionInstance @relation(fields: [instanceId], references: [id])

  @@id([instanceId, topic])
}
