# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lotusrank?schema=lotusrank"

# Indexer configuration for RANK genesis block
# Height of the RANK genesis block
RANK_GENESIS_HEIGHT=952169
# Hash of the RANK genesis block
RANK_GENESIS_HASH=0000000000c974cb635064bec0db8cc64a75526871f581ea5dbeca7a98551546

# Referral System
# Secret key used for HMAC signing of referral codes
REFERRAL_SECRET=your-referral-hmac-secret-here
# Secret key for admin authentication
ADMIN_SECRET=your-admin-secret-here

# VAPID Push Notifications
# Contact email for VAPID identification
VAPID_SUBJECT=mailto:stewardship@lotusia.org
# Public key for VAPID push notifications
VAPID_PUBLIC_KEY=
# Private key for VAPID push notifications
VAPID_PRIVATE_KEY=
# Google Cloud Messaging API key for push notifications (deprecated)
GCM_API_KEY=

# Temporal Workflow Orchestration
# Host address for Temporal server
TEMPORAL_HOST=localhost:7233
# Temporal namespace to use
TEMPORAL_NAMESPACE=default
# Task queue name for Temporal workers
TEMPORAL_TASKQUEUE=rank-task-queue
# Workflow type for command processing
TEMPORAL_COMMAND_WORKFLOW_TYPE=commandWorkflow
# Unique workflow ID for command workflow
TEMPORAL_COMMAND_WORKFLOW_ID=command-workflow
# Signal name for command workflow
TEMPORAL_COMMAND_WORKFLOW_SIGNAL=commandSignal
# Workflow ID for wallet activity charts API
TEMPORAL_API_CHARTS_WALLET_ACTIVITY=charts-wallet-activity
# Query type for retrieving chart data
TEMPORAL_API_CHARTS_WALLET_ACTIVITY_QUERY_TYPE=getChartData
